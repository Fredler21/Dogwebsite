rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin()    { return isSignedIn() && request.auth.token.admin == true; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isCreate()   { return resource == null; }
    function isUpdate()   { return resource != null; }

    function isString(v, max)   { return v is string && v.size() <= max; }
    function isNumber(v)        { return v is number; }
    function isPosNumber(v)     { return v is number && v >= 0; }
    function isEmail(v)         { return v is string && v.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$'); }

    // --- Public, read-only collections -------------------------------------
    match /products/{id} {
      allow read: if resource.data.active == true || isAdmin();
      allow write: if isAdmin();
    }
    match /categories/{id} {
      allow read: if resource.data.active == true || isAdmin();
      allow write: if isAdmin();
    }
    match /landingPages/{id} {
      allow read: if resource.data.published == true || isAdmin();
      allow write: if isAdmin();
    }

    // --- Customer-owned data -----------------------------------------------
    match /orders/{orderId} {
      // Customers read only their own paid orders. Admin reads all.
      allow read: if isAdmin() || isOwner(resource.data.userId);
      // Orders are created server-side (Stripe webhook). Customers may not write.
      allow create, update, delete: if isAdmin();
    }

    match /carts/{cartId} {
      allow read, write: if isAdmin() || isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /users/{uid} {
      allow read: if isAdmin() || isOwner(uid);
      allow update: if isOwner(uid) &&
        !('admin' in request.resource.data) &&
        !('roles' in request.resource.data); // privilege escalation guard
      allow create: if isOwner(uid);
      allow delete: if isAdmin();
    }

    // --- Support tickets ---------------------------------------------------
    match /supportTickets/{id} {
      allow read: if isAdmin();
      // Anonymous + authenticated may create with strict validation.
      allow create: if request.resource.data.keys().hasOnly([
        'customerEmail','category','subject','message','orderId',
        'priority','status','createdAt','updatedAt'
      ]) &&
        isEmail(request.resource.data.customerEmail) &&
        isString(request.resource.data.subject, 200) &&
        isString(request.resource.data.message, 5000) &&
        request.resource.data.status == 'open' &&
        request.resource.data.priority in ['low','medium','high','urgent'] &&
        request.resource.data.category in
          ['tracking','refund','return','damaged','wrong_item','payment','general'];
      allow update, delete: if isAdmin();
    }

    // --- Admin-only collections --------------------------------------------
    match /suppliers/{id}         { allow read, write: if isAdmin(); }
    match /supplierOrders/{id}    { allow read, write: if isAdmin(); }
    match /discounts/{id}         { allow read, write: if isAdmin(); }
    match /aiLogs/{id}            { allow read: if isAdmin(); allow write: if false; } // server-only
    match /aiAlerts/{id}          { allow read, update: if isAdmin(); allow create, delete: if false; }
    match /aiReports/{id}         { allow read: if isAdmin(); allow write: if false; }
    match /auditLogs/{id}         { allow read: if isAdmin(); allow write: if false; }
    match /emailLogs/{id}         { allow read: if isAdmin(); allow write: if false; }
    match /emailQueue/{id}        { allow read, write: if isAdmin(); }
    match /experiments/{id}       { allow read, write: if isAdmin(); }
    match /stores/{id}            { allow read: if true; allow write: if isAdmin(); }
    match /config/{id}            { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /rateLimits/{id}        { allow read, write: if false; } // server-only

    // Default deny.
    match /{document=**} { allow read, write: if false; }
  }
}
