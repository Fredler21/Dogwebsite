rules_version = '2';

// Allyoucanuse.com — Firestore security rules (V2 baseline).
// Strategy mirrors prd.md section 12.1. Strict mode lands in V9.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin()    { return isSignedIn() && request.auth.token.admin == true; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // Public-readable storefront data
    match /products/{id} {
      allow read:  if resource.data.status == 'active' || isAdmin();
      allow write: if isAdmin();
    }
    match /categories/{id} {
      allow read:  if resource.data.status == 'active' || isAdmin();
      allow write: if isAdmin();
    }

    // Customers — own data only
    match /customers/{uid} {
      allow read, update: if isOwner(uid) || isAdmin();
      allow create:       if isOwner(uid);
      allow delete:       if isAdmin();
    }

    // Orders — customer reads own; client cannot mutate paymentStatus/fulfillmentStatus.
    // Cloud Functions (admin SDK) bypass these rules.
    match /orders/{id} {
      allow read:   if isAdmin() ||
                       (isSignedIn() && (resource.data.customerId == request.auth.uid ||
                                         resource.data.customerEmail == request.auth.token.email));
      allow create: if false; // only via Cloud Function
      allow update: if isAdmin(); // never from public client
      allow delete: if false;
    }

    // Carts — public create allowed for guests; ownership enforced
    match /carts/{id} {
      allow read, write: if isAdmin() ||
                            (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if true; // guest carts allowed
    }

    // Support tickets — anyone can create, only admin/owner can read
    match /supportTickets/{id} {
      allow create: if request.resource.data.keys().hasAll(['customerEmail','category','subject','message'])
                       && request.resource.data.message.size() >= 10
                       && request.resource.data.message.size() <= 5000;
      allow read, update: if isAdmin() ||
                             (isSignedIn() && resource.data.customerEmail == request.auth.token.email);
      allow delete: if isAdmin();
    }

    // Admin-only collections
    match /aiAlerts/{id}      { allow read, write: if isAdmin(); }
    match /aiLogs/{id}        { allow read, write: if isAdmin(); }
    match /auditLogs/{id}     { allow read, write: if isAdmin(); }
    match /suppliers/{id}     { allow read, write: if isAdmin(); }
    match /discounts/{id}     { allow read, write: if isAdmin(); }

    // Store settings — public read of the safe doc only
    match /settings/public    { allow read: if true; allow write: if isAdmin(); }
    match /settings/{doc}     { allow read, write: if isAdmin(); }
  }
}
